{
  "name": "tne_website",
  "version": "1.0.0",
  "type": "module",
  "description": "TNE United Express youth basketball website",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:unit": "cd react-app && npm run test:unit",
    "test:e2e:submissions": "npx playwright test --project=form-submissions",
    "test:e2e:verify": "npx playwright test --project=data-verification",
    "test:e2e:public": "npx playwright test --project=public-pages",
    "test:smoke": "npx playwright test --project=smoke",
    "lint:react": "cd react-app && npm run lint",
    "validate:data": "node scripts/validate-json-schema.js",
    "build:react": "npm run validate:data && cd react-app && npm run build",
    "pr-check": "npm run lint:react && npm run build:react && npm run test",
    "update-teams": "node scripts/excel-to-json.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx scripts/seed-dev-data.ts",
    "db:seed:winter-2025": "npx tsx scripts/seed-winter-2025.ts",
    "db:seed:users": "npx tsx scripts/seed-test-users.ts",
    "db:create-admin": "npx tsx scripts/create-admin.ts",
    "db:migrate-from-supabase": "npx tsx scripts/migrate-from-supabase.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@neondatabase/serverless": "^1.0.2",
    "better-auth": "^1.4.18",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^25.2.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
