{
  "name": "tne_website",
  "version": "1.0.0",
  "type": "module",
  "description": "TNE United Express youth basketball website",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:e2e:submissions": "npx playwright test --project=form-submissions",
    "test:e2e:verify": "npx playwright test --project=data-verification",
    "test:e2e:public": "npx playwright test --project=public-pages",
    "test:smoke": "npx playwright test --project=smoke",
    "validate:data": "node scripts/validate-json-schema.js",
    "pr-check": "eslint . && next build && npx playwright test",
    "update-teams": "node scripts/excel-to-json.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx scripts/seed-dev-data.ts",
    "db:seed:winter-2025": "npx tsx scripts/seed-winter-2025.ts",
    "db:seed:summer-2026": "npx tsx scripts/seed-summer-2026.ts",
    "db:seed:users": "npx tsx scripts/seed-test-users.ts",
    "db:create-admin": "npx tsx scripts/create-admin.ts",
    "db:migrate-from-supabase": "npx tsx scripts/migrate-from-supabase.ts",
    "db:backup": "./scripts/backup-db.sh",
    "db:backup:dev": "./scripts/backup-db.sh --dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@neondatabase/auth": "^0.1.0-beta.21",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/nextjs": "^10.40.0",
    "@vercel/analytics": "^1.6.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.562.0",
    "next": "^15.3.0",
    "posthog-js": "^1.356.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.9.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.16",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.3.0",
    "jsdom": "^27.3.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  }
}
