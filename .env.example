# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Server-Side (for API routes - bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic API (for AI chat assistant)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Places API (for tournament research agent)
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Auth Timeouts (optional, in milliseconds)
# VITE_AUTH_INIT_TIMEOUT=10000
# VITE_SIGN_IN_TIMEOUT=15000

# Test User Credentials (for E2E tests)
TEST_ADMIN_EMAIL=admin@tneexpress.com
TEST_ADMIN_PASSWORD=
TEST_COACH_EMAIL=coach@tneexpress.com
TEST_COACH_PASSWORD=
TEST_PARENT_EMAIL=parent@tneexpress.com
TEST_PARENT_PASSWORD=
