# ===========================================
# TNE WEBSITE - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# DATABASE
# -------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -------------------------------------------
# BETTER AUTH (Server-Side)
# -------------------------------------------
# REQUIRED in production — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here

# Canonical app URL (used for callbacks, cookie domain, CORS)
APP_URL=http://localhost:3000

# Optional: Better Auth also reads this (APP_URL takes precedence)
# BETTER_AUTH_URL=http://localhost:3000

# -------------------------------------------
# NEXT.JS PUBLIC (Client-Side)
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# -------------------------------------------
# EMAIL (Resend)
# -------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxx
# Comma-separated admin emails for registration notifications
ADMIN_NOTIFICATION_EMAILS=pernell@gmail.com

# -------------------------------------------
# TEST CREDENTIALS (for seed scripts only)
# -------------------------------------------
TEST_ADMIN_EMAIL=admin@tnebasketball.com
TEST_ADMIN_PASSWORD=TestAdmin123!
