# ===========================================
# TNE WEBSITE - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# DATABASE
# -------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -------------------------------------------
# BETTER AUTH (Server-Side)
# -------------------------------------------
# REQUIRED in production — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here

# Canonical app URL (used for callbacks, cookie domain, CORS)
APP_URL=http://localhost:3000

# Optional: Better Auth also reads this (APP_URL takes precedence)
# BETTER_AUTH_URL=http://localhost:3000

# -------------------------------------------
# NEXT.JS PUBLIC (Client-Side)
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# -------------------------------------------
# CLOUDFLARE TURNSTILE (Server-Side)
# -------------------------------------------
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# -------------------------------------------
# EMAIL (Resend)
# -------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxx
# Comma-separated admin emails for registration notifications
ADMIN_NOTIFICATION_EMAILS=pernell@gmail.com

# -------------------------------------------
# DATABASE SAFETY
# -------------------------------------------
# The unique endpoint identifier from your production Neon branch connection string.
# Used by scripts/lib/db-guard.ts to block seed scripts from running against production.
# Example: if your prod URL is postgresql://user@ep-cool-name-123456.us-east-2.aws.neon.tech/...
# then set this to: ep-cool-name-123456
NEON_PRODUCTION_ENDPOINT=

# -------------------------------------------
# SENTRY ERROR TRACKING
# -------------------------------------------
# Client-side DSN (public, safe to expose in browser)
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source map uploads (server-side only, get from sentry.io)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -------------------------------------------
# TEST CREDENTIALS (for seed scripts only)
# -------------------------------------------
TEST_ADMIN_EMAIL=admin@tnebasketball.com
TEST_ADMIN_PASSWORD=TestAdmin123!
