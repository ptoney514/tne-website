{
  "buildCommand": "npm install && cd react-app && npm install && npm run build",
  "outputDirectory": "react-app/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
