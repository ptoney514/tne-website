{
  "buildCommand": "npm install && cd react-app && npm install && npm run build",
  "outputDirectory": "react-app/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/auth/[...betterauth].ts": {
      "includeFiles": "api/lib/**"
    }
  },
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/auth/[...betterauth]" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
